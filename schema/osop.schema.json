{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osop.ai/schema/v2.1.0/osop.schema.json",
  "title": "OSOP Workflow Schema",
  "type": "object",
  "required": ["osop_version", "id", "name", "nodes", "edges"],
  "additionalProperties": false,
  "patternProperties": { "^x-": {} },
  "properties": {
    "osop_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "owner": { "type": "string" },
    "visibility": { "type": "string", "enum": ["public", "private"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "description": "Lifecycle status of this workflow definition.",
      "type": "string",
      "enum": ["draft", "active", "deprecated", "template"],
      "default": "active"
    },
    "usage": {
      "description": "Intended purpose of this .osop file.",
      "type": "string",
      "enum": ["plan", "execution", "template", "reference"],
      "default": "execution"
    },
    "workflow_type": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "array", "items": { "type": "string" } }
      }
    },
    "extends": {
      "description": "Inheritance: base workflow id or path.",
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "change_summary": { "type": "string" }
      }
    },
    "schemas": {
      "description": "Schema registry (JSON Schema fragments).",
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "triggers": {
      "description": "Workflow trigger definitions.",
      "type": "array",
      "items": { "$ref": "#/$defs/trigger" }
    },
    "variables": {
      "description": "Workflow-level variables.",
      "type": "object",
      "additionalProperties": true
    },
    "imports": {
      "description": "URIs to external node definitions or sub-workflows.",
      "type": "array",
      "items": { "type": "string", "format": "uri-reference" }
    },
    "env": {
      "description": "Environment variable mapping.",
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "platforms": {
      "description": "Target platforms for this workflow.",
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["linux", "windows", "macos", "ios", "android", "web", "any"]
      }
    },
    "conformance_level": {
      "description": "0 = descriptive, 1 = validatable, 2 = executable, 3 = observable.",
      "type": "integer",
      "enum": [0, 1, 2, 3]
    },
    "version": {
      "description": "Workflow version (SemVer).",
      "type": "string"
    },
    "timeout_sec": {
      "description": "Workflow-level timeout in seconds. Cascades to all nodes (v1.1).",
      "type": "number",
      "minimum": 0
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/edge" }
    },
    "message_contracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/messageContract" }
    },
    "tests": {
      "type": "array",
      "items": { "$ref": "#/$defs/testCase" }
    },
    "views": {
      "type": "array",
      "items": { "type": "string", "enum": ["graph", "story", "role", "debug", "agent"] }
    },
    "security": { "$ref": "#/$defs/securityPolicy" },
    "observability": { "$ref": "#/$defs/observabilityPolicy" },
    "evolution": { "$ref": "#/$defs/evolutionPolicy" },
    "ledger": { "$ref": "#/$defs/ledgerPolicy" }
  },
  "$defs": {
    "trigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cron", "webhook", "git_push", "manual", "event"]
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["human", "agent", "api", "cli", "db", "git", "docker", "cicd", "mcp", "system", "infra", "data"]
        },
        "subtype": { "type": "string" },
        "role": { "type": "string" },
        "owner": { "type": "string" },
        "purpose": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "cost": {
          "description": "Estimated cost metadata for this node.",
          "type": "object",
          "additionalProperties": true
        },
        "message_contract": {
          "description": "Message contract for inter-node communication.",
          "type": "object",
          "additionalProperties": true
        },
        "runtime": {
          "description": "Node runtime config.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" },
            "os": { "type": "string" },
            "image": { "type": "string" },
            "command": { "type": "string" },
            "endpoint": { "type": "string" },
            "repo": { "type": "string" },
            "action": { "type": "string" },
            "branch": { "type": "string" },
            "engine": { "type": "string" },
            "table": { "type": "string" },
            "environment": { "type": "string" },
            "method": { "type": "string" },
            "url": { "type": "string" },
            "system_prompt": {
              "description": "System prompt for agent type nodes.",
              "type": "string"
            },
            "temperature": {
              "description": "Temperature setting for agent type nodes.",
              "type": "number"
            },
            "max_tokens": {
              "description": "Max tokens for agent type nodes.",
              "type": "integer"
            },
            "tools": {
              "description": "MCP tool references for agent type nodes.",
              "type": "array",
              "items": { "type": "string" }
            },
            "headers": {
              "description": "HTTP headers for api type nodes.",
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "body_template": {
              "description": "Body template for api type nodes.",
              "oneOf": [
                { "type": "string" },
                { "type": "object" }
              ]
            },
            "auth": {
              "description": "Authentication config for api type nodes.",
              "type": "object",
              "additionalProperties": false,
              "patternProperties": { "^x-": {} },
              "properties": {
                "type": { "type": "string" },
                "secret_ref": { "type": "string" }
              }
            },
            "tool": {
              "description": "Infrastructure tool for infra type nodes (e.g., terraform, kubernetes, ansible, pulumi, helm).",
              "type": "string"
            },
            "config_path": {
              "description": "Configuration path for infra type nodes.",
              "type": "string"
            },
            "connection": {
              "description": "Connection string or reference for data type nodes.",
              "type": "string"
            },
            "source": {
              "description": "Data source for data type nodes.",
              "type": "object",
              "additionalProperties": true
            },
            "destination": {
              "description": "Data destination for data type nodes.",
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ioSpec" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ioSpec" }
        },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retry_policy": { "$ref": "#/$defs/retryPolicy" },
        "timeout_sec": { "type": "number", "minimum": 0 },
        "idempotency": { "$ref": "#/$defs/idempotencyPolicy" },
        "handoff": { "$ref": "#/$defs/handoffSpec" },
        "explain": { "$ref": "#/$defs/explainSpec" },
        "observability": { "$ref": "#/$defs/observabilityNode" },
        "security": { "$ref": "#/$defs/securityNode" },
        "approval_gate": {
          "oneOf": [
            { "type": "boolean" },
            { "$ref": "#/$defs/approvalGate" }
          ]
        },
        "parent": {
          "description": "ID of parent node that spawns this agent (OSP-0001).",
          "type": "string"
        },
        "spawn_policy": {
          "description": "Constraints for agent spawning (OSP-0001).",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_children": { "type": "integer", "minimum": 1 },
            "child_tools": { "type": "array", "items": { "type": "string" } },
            "can_spawn_children": { "type": "boolean", "default": false }
          }
        },
        "workflow_ref": {
          "description": "URI or id of imported sub-workflow to execute as this node (v1.1).",
          "type": "string"
        },
        "workflow_inputs": {
          "description": "Input parameters to pass to the sub-workflow (v1.1).",
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ioSpec": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "schema": { "type": "string" },
            "required": { "type": "boolean", "default": false },
            "description": { "type": "string" },
            "explain": { "$ref": "#/$defs/explainSpec" }
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["sequential", "conditional", "parallel", "loop", "event", "fallback", "error", "timeout", "spawn", "switch"],
          "default": "sequential"
        },
        "when": {
          "description": "Condition expression.",
          "$comment": "Expression language: CEL (Common Expression Language). See https://osop.ai/docs/expression-language",
          "type": "string"
        },
        "condition": {
          "description": "Alias for 'when' (backward compatibility).",
          "type": "string"
        },
        "explain": { "$ref": "#/$defs/explainSpec" },
        "label": { "type": "string" },
        "spawn_count": {
          "description": "Number of child agents to spawn (for spawn edge mode).",
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "for_each": {
          "description": "CEL expression resolving to a list for iteration (v1.1).",
          "type": "string"
        },
        "iterator_var": {
          "description": "Variable name for current iteration item (v1.1).",
          "type": "string"
        },
        "join_mode": {
          "description": "How parallel branches are joined (v1.1).",
          "type": "string",
          "enum": ["wait_all", "wait_any", "wait_n"],
          "default": "wait_all"
        },
        "join_count": {
          "description": "Number of branches to wait for in wait_n mode (v1.1).",
          "type": "integer",
          "minimum": 1
        },
        "cases": {
          "description": "Switch/case routing table (v1.1).",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["to"],
            "properties": {
              "value": {},
              "to": { "type": "string" }
            }
          }
        },
        "default_to": {
          "description": "Default target for switch edge when no case matches (v1.1).",
          "type": "string"
        }
      }
    },
    "messageContract": {
      "type": "object",
      "required": ["id", "producer", "consumer", "kind", "format"],
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "id": { "type": "string" },
        "producer": { "type": "string" },
        "consumer": { "type": "string" },
        "kind": { "type": "string", "enum": ["task", "result", "state", "error", "event"] },
        "format": { "type": "string", "enum": ["json", "text"] },
        "schema_ref": {
          "description": "Reference into schemas registry.",
          "type": "string"
        },
        "semantics": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "testCase": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["unit", "integration", "e2e", "simulation"] },
        "target_node": { "type": "string" },
        "run": { "type": "string", "enum": ["full_workflow"] },
        "input": { "type": "object", "additionalProperties": true },
        "expect": { "type": "object", "additionalProperties": true },
        "mocks": { "type": "object", "additionalProperties": true },
        "failure_injection": { "type": "object", "additionalProperties": true }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "max_retries": { "type": "number", "minimum": 0, "default": 0 },
        "strategy": { "type": "string", "enum": ["fixed", "exponential_backoff"], "default": "fixed" },
        "backoff_sec": { "type": "number", "minimum": 0 }
      }
    },
    "idempotencyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "key": {
          "description": "Idempotency key expression.",
          "type": "string"
        }
      }
    },
    "handoffSpec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary_for_next_node": { "type": "string" },
        "expected_output": { "type": "string" },
        "escalation": { "type": "string" },
        "from": { "type": "string" },
        "context_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "explainSpec": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": { "^x-": {} },
          "properties": {
            "why": { "type": "string" },
            "what": { "type": "string" },
            "result": { "type": "string" }
          }
        }
      ]
    },
    "observabilityPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "emit_events": { "type": "boolean", "default": true },
        "trace_id_required": { "type": "boolean", "default": true },
        "default_log_level": { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" },
        "log_level": { "type": "string" },
        "tracing": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "audit_trail": {
          "oneOf": [
            { "type": "string" },
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        }
      }
    },
    "observabilityNode": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "log": { "type": "boolean", "default": true },
        "metrics": {
          "type": "array",
          "items": { "type": "string", "enum": ["duration_ms", "retry_count", "success_rate", "cost_units"] }
        }
      }
    },
    "securityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "secrets_provider": {
          "description": "e.g., vault, aws_secrets_manager, github_secrets",
          "type": "string"
        },
        "default_permissions": { "type": "array", "items": { "type": "string" } },
        "approval_required_for": { "type": "array", "items": { "type": "string" } }
      }
    },
    "securityNode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "permissions": { "type": "array", "items": { "type": "string" } },
        "secrets": { "type": "array", "items": { "type": "string" } },
        "credentials": { "type": "array", "items": { "type": "string" } },
        "risk_level": { "type": "string" },
        "access_control": { "type": "string" },
        "data_classification": { "type": "string" },
        "encryption": { "type": "string" },
        "model_governance": {
          "oneOf": [
            { "type": "string" },
            { "type": "object", "additionalProperties": true }
          ]
        }
      }
    },
    "approvalGate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required": { "type": "boolean", "default": false },
        "approver_role": { "type": "string" },
        "approvers": { "type": "array", "items": { "type": "string" } },
        "timeout_hours": { "type": "number" },
        "bypass_allowed": { "type": "boolean" },
        "mandatory": { "type": "boolean" }
      }
    },
    "evolutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x-": {} },
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "strategy": { "type": "string", "enum": ["ai_assisted", "manual"], "default": "ai_assisted" },
        "feedback_sources": {
          "type": "array",
          "items": { "type": "string", "enum": ["logs", "metrics", "human_feedback"] }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": { "^x-": {} },
          "properties": {
            "mode": { "type": "string", "enum": ["pull_request", "patch_only"], "default": "pull_request" },
            "require_human_approval": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "ledgerPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "store": { "type": "string" },
        "storage": { "type": "string" },
        "artifact_store": { "type": "string" }
      }
    }
  }
}
